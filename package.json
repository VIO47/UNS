{
  "name": "comparison-app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --import tsx/esm src/server/index.ts",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node --import tsx/esm src/server/db/init.ts",
    "db:migrate": "node --import tsx/esm src/server/db/cli.ts up",
    "db:rollback": "node --import tsx/esm src/server/db/cli.ts down"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.100.4",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "axios": "^1.6.0",
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.2",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trpc/next": "^11.16.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  }
}
